# =============================================================================
# .env.example - Variaveis de ambiente do ETL S&OE (painel GLB-GFM)
# =============================================================================
#
# Copie este arquivo para .env e preencha. O .env e ignorado pelo git.
#   cp .env.example .env
#
# ATENCAO (gotcha): NAO use comentario inline na mesma linha de um valor.
#   ERRADO:  MC_SAMPLES=50000   # numero de amostras   <- o comentario vira valor
#   CERTO:   MC_SAMPLES=50000
# Coloque comentarios SOMENTE em linhas proprias (comecando com #).
#
# So ative o agendamento (launchd) DEPOIS de preencher este arquivo.
# =============================================================================

# --- Fonte de dados ----------------------------------------------------------
# Qual adaptador o ETL deve usar para ler os dados.
# Valores: sql | powerbi | sqlite   (sinonimo aceito: fixture)
#   sql              -> le de um banco SQL (preencha SOE_SQL_*)
#   powerbi          -> le de um dataset Power BI via DAX (preencha PBI_*)
#   sqlite / fixture -> SQLite local em fixtures/ (modo demo, sem credencial)
SOE_SOURCE=sql

# Nivel de servico alvo (%) usado por sql/powerbi (no modo sqlite vem do banco).
SOE_NS_META=95

# --- Adaptador SQL (usado quando SOE_SOURCE=sql) -----------------------------
# URL de conexao SQLAlchemy. Exemplos:
#   SQL Server (pyodbc): mssql+pyodbc://USER:SENHA@HOST:1433/BASE?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes
#   Postgres:            postgresql+psycopg2://USER:SENHA@HOST:5432/BASE
SOE_SQL_URL=

# Query que retorna as linhas do plano S&OE, ja com os ALIASES do contrato
# (ver SETUP.md / soe/sources.py EXPECTED_COLUMNS para a lista completa).
SOE_SQL_QUERY=

# Capacidades de linha (OPCIONAL, p/ sql/powerbi) em JSON. Sem isto, as metricas
# de capacidade/utilizacao ficam vazias. No modo sqlite vem do proprio banco.
# Ex.: [{"linha":"Laminacao","capacidade_t":5000,"utilizado_t":4300}]
SOE_LINHAS_JSON=

# --- Adaptador Power BI (usado quando SOE_SOURCE=powerbi) --------------------
# Service principal (Azure AD) com acesso ao workspace/dataset.
PBI_TENANT_ID=
PBI_CLIENT_ID=
PBI_CLIENT_SECRET=
# ID do dataset alvo da consulta DAX. PBI_GROUP_ID (workspace) e opcional.
PBI_GROUP_ID=
PBI_DATASET_ID=
# Consulta DAX que devolve as colunas do contrato (ver exemplo no SETUP.md).
PBI_DAX_QUERY=

# --- E-mail de alerta (Gmail SMTP) -------------------------------------------
# Conta Gmail remetente e SENHA DE APP (NAO a senha normal da conta).
# Gere em: myaccount.google.com -> Seguranca -> Verificacao em 2 etapas
#          -> Senhas de app. Cole aqui os 16 caracteres (sem espacos).
SOE_GMAIL_USER=
SOE_GMAIL_APP_PASSWORD=

# Destinatario dos alertas de execucao (rupturas, excessos, falha de ETL).
ALERT_TO=emiliodias1@gmail.com

# --- Monte Carlo -------------------------------------------------------------
# Numero de amostras da simulacao de risco. Mais = mais preciso e mais lento.
# Com numpy instalado, 50000 roda rapido; em Python puro, considere reduzir.
MC_SAMPLES=50000

# --- Dashboard (GitHub Pages) ------------------------------------------------
# URL publica do painel; usada nos links do e-mail de alerta.
DASH_URL=https://joseedson18jc.github.io/painel-soe-glb-gfm/
